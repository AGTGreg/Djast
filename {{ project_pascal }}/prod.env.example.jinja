# =============================================================================
# {{ project_name }} Production Environment
# Copy this file to prod.env and fill in all required values.
# =============================================================================

# General
DEBUG=0
TIME_ZONE="UTC"

# SECURITY — REQUIRED: Generate a unique secret key.
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="CHANGE-ME-generate-a-secret-key"

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_ENGINE="postgresql"
DB_HOST="db"
DB_PORT=5432
DB_NAME="{{ project_slug }}"
DB_USER="{{ project_slug }}"
DB_PASSWORD="CHANGE-ME-use-a-strong-password"

# PostgreSQL container credentials (must match DB_* values above)
POSTGRES_DB="{{ project_slug }}"
POSTGRES_USER="{{ project_slug }}"
POSTGRES_PASSWORD="CHANGE-ME-use-a-strong-password"

# =============================================================================
# Redis
# =============================================================================
REDIS_URL="redis://redis:6379/1"
RATE_LIMIT_REDIS_URL="redis://redis:6379/2"

# =============================================================================
# Task Queue (TaskIQ)
# =============================================================================
TASKIQ_BROKER_URL="redis://redis:6379/3"
TASKIQ_RESULT_BACKEND_URL="redis://redis:6379/4"
EMAIL_USE_TASKIQ=1

# =============================================================================
# CORS — Set to your frontend domain(s), comma-separated JSON list
# =============================================================================
CORS_ALLOW_ORIGINS='["https://yourdomain.com"]'

# =============================================================================
# Email (SMTP)
# =============================================================================
EMAIL_BACKEND="djast.utils.email_backends.smtp.SMTPEmailBackend"
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
DEFAULT_FROM_EMAIL="noreply@yourdomain.com"

# =============================================================================
# Proxy (Granian behind Nginx)
# =============================================================================
# "*" is safe when the app port is only reachable by the Nginx container.
# Restrict to a CIDR (e.g. "172.16.0.0/12") if the app port is exposed.
PROXY_TRUSTED_HOSTS="*"

# =============================================================================
# OAuth (disabled by default — uncomment and configure to enable)
# =============================================================================
# OAUTH_GOOGLE_ENABLED=1
# OAUTH_GOOGLE_CLIENT_ID=""
# OAUTH_GOOGLE_CLIENT_SECRET=""
# OAUTH_GITHUB_ENABLED=1
# OAUTH_GITHUB_CLIENT_ID=""
# OAUTH_GITHUB_CLIENT_SECRET=""
# OAUTH_LOGIN_REDIRECT_URL="https://yourdomain.com/auth/callback"

# =============================================================================
# Auth settings (defaults are fine for most deployments)
# =============================================================================
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ALLOW_SIGNUP=1

# Email verification: "mandatory" | "optional" | "none"
# EMAIL_VERIFICATION="none"
# EMAIL_VERIFICATION_URL="https://yourdomain.com/auth/verify-email"
# PASSWORD_RESET_URL="https://yourdomain.com/auth/reset-password"
