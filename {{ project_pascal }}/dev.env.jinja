DEBUG=1
TIME_ZONE="UTC"

# SECURITY
SECRET_KEY="GENERATE_ME"
PASSWORD_HASHER="pbkdf2_sha256"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth
AUTH_USER_MODEL_TYPE="{{ auth_user_model }}"

# Task Queue
TASKIQ_BROKER_URL="redis://redis:6379/3"
TASKIQ_RESULT_BACKEND_URL="redis://redis:6379/4"
EMAIL_USE_TASKIQ=0

# DB
# SQLITE specific configuration
# DB_ENGINE="sqlite"
# DB_NAME="db.sqlite3"
# DB_PASSWORD="GENERATE_ME"

# PostgreSQL specific configuration
DB_ENGINE="postgresql"
DB_HOST="db"
DB_PORT=5432
DB_NAME="mydatabase"
DB_USER="myuser"
DB_PASSWORD="GENERATE_ME"

# PostgreSQL container init (must match DB_USER/DB_PASSWORD/DB_NAME above)
POSTGRES_USER="myuser"
POSTGRES_PASSWORD="GENERATE_ME"
POSTGRES_DB="mydatabase"
